            if (array_key_exists('list_[TABLE_NAME]',$_SESSION) && array_key_exists('page',$_SESSION['list_[TABLE_NAME]']))
            {
                $this->page = $_SESSION['list_[TABLE_NAME]']['page'];
            }            
        }
        if (($this->page < 1) || ($this->page > $this->pages)) $this->page = 1;
